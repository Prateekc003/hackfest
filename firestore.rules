rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Owner full access
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Other authenticated users can read (for leaderboard — name + totalFocusMinutes only)
      allow read: if request.auth != null;

      match /focusSessions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /moodLog/{id} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /activeDays/{id} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /simplifications/{id} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Report audit logs — only Cloud Functions (admin SDK) can write; no client read
    match /reportLogs/{id} {
      allow read, write: if false;
    }
  }
}
